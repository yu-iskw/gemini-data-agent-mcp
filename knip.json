{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["grype"],
  "workspaces": {
    ".": {
      "entry": ["stylelint.config.mjs"],
      "project": ["**/*.{js,cjs,mjs,ts,cts,mts}", "!packages/**", "!.trunk/**", "!node_modules/**"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/analyst-mcp": {
      "ignoreDependencies": ["js-yaml"]
    },
    "packages/admin-mcp": {
      "ignoreDependencies": ["js-yaml"]
    },
    "packages/audit-mcp": {
      "ignoreDependencies": ["google-auth-library"]
    },
    "packages/agentops-mcp": {
      "ignoreDependencies": ["google-auth-library"]
    }
  }
}
