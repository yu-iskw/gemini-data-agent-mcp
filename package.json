{
  "name": "typescript-template",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "",
  "scripts": {
    "build": "pnpm --recursive build",
    "trunk": "trunk",
    "format": "pnpm format:trunk",
    "format:all": "pnpm format:trunk-all",
    "format:eslint": "eslint . --fix",
    "format:prettier": "prettier --write .",
    "format:trunk": "trunk fmt",
    "format:trunk-all": "trunk fmt --all",
    "lint": "pnpm lint:trunk",
    "lint:all": "pnpm lint:trunk-all && pnpm security:grype",
    "lint:eslint": "eslint .",
    "lint:security": "trunk check --all --scope security",
    "lint:trunk": "trunk check -y",
    "lint:trunk-all": "trunk check --all -y",
    "security:grype": "grype .",
    "knip": "knip",
    "codeql:local": "bash dev/codeql.sh",
    "test": "vitest run",
    "publish:npm:analyst": "pnpm config set node-linker hoisted && pnpm install && pnpm build && pnpm publish --filter @gemini-data-agents/analyst-mcp --no-git-checks --access public"
  },
  "devDependencies": {
    "@trunkio/launcher": "^1.3.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/eslint-plugin": "^1.6.14",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "knip": "^6.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "overrides": {
      "tar": "7.5.11",
      "fast-uri@<=3.1.0": ">=3.1.1",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "hono@<4.12.18": ">=4.12.18",
      "ip-address@<=10.1.0": ">=10.1.1",
      "hono@<4.12.16": ">=4.12.16",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "hono@<4.12.21": ">=4.12.21",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1"
    }
  },
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10.28.1"
  }
}
